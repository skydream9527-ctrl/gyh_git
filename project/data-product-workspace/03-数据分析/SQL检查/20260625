with t_tar as (
    SELECT
        new_flag,
        cp_name,
        valid_flag,
        exp_id,
        sum(if (expose_tally>0, xiaofei_duration/60000, 0))/count(distinct if (expose_tally>0, distinct_id, null)) as avg_dur
    from
        dw.dwm_browser_feeds_user_exp_di_v2
    where
        date=${date-1}
    group by
        new_flag,
        cp_name,
        valid_flag,
        exp_id
    with
        cube
)
INSERT OVERWRITE table iceberg_zjyprc_hadoop.browser.feeds_exp_avg_xiaofeiduration partition (date=${date-1})
SELECT
    user_type,
    valid_type,
    exp_id,
    avg_dur,
    cp_name
from
    (
        SELECT
            case
                when new_flag=1 then '新用户'
                when new_flag=0 then '老用户'
                when new_flag is null then '大盘用户'
                else 'other'
            end as user_type,
            if (cp_name is null, '大盘流量', cp_name) as cp_name,
            case
                when valid_flag=1 then '有效用户'
                when valid_flag=0 then '无效用户'
                when valid_flag is null then '大盘用户'
                else 'other'
            end as valid_type,
            exp_id,
            avg_dur
        from
            t_tar
    ) a
where
    valid_type!='无效用户'
    and user_type!='老用户'


;


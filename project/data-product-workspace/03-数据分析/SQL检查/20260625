insert overwrite table hive_zjyprc_hadoop.dw.dwm_browser_feeds_user_exp_di_v2 partition (date=${date - 1})
select
    did,
    new_flag,
    cp_name,
    exp_id,
    open_tally,
    valid_flag,
    search_tally,
    expose_tally,
    click_tally,
    vv_tally,
    feed_dur,
    xiaofei_duration,
    news_v,
    short_v,
    mini_v,
    sum(expose_tally) over (
        PARTITION by
            did
    ) sum_expose_flag,
    sum(open_tally) over (
        PARTITION by
            did
    ) sum_open_flag
FROM
    result
;






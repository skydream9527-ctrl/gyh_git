,result as (
    select
        a.did
        ,new_flag
        ,cp_name
        ,exp_id
        ,open_tally
        ,valid_flag
        ,coalesce(search_tally,0) as search_tally
        ,expose_tally
        ,click_tally
        ,vv_tally
        ,feed_dur
        ,xiaofei_duration
        ,news_v
        ,short_v
        ,mini_v
    from
        (
            SELECT
                did
                ,exp_id
                ,max(new_flag) as new_flag
                ,max(valid_flag) as valid_flag
                ,max(cp_name) as cp_name
                ,sum(open_tally) as open_tally
                ,sum(expose_tally) as expose_tally
                ,sum(click_tally) as click_tally
                ,sum(vv_tally) as vv_tally
                ,sum(feed_dur) as feed_dur
                ,sum(xiaofei_duration) as xiaofei_duration
                ,sum(news_v) as news_v
                ,sum(short_v) as short_v
                ,sum(mini_v) as mini_v
            from
                t_explode0
            where
                coalesce(exp_id,'') != ''
            group by
                did,
                exp_id
        ) a
        left join (
            SELECT
                did
                ,sum(search_security_cnt) as search_tally
            FROM
                iceberg_zjyprc_hadoop.browser.dwm_browser_event_aggregation_label_di
            WHERE
                date=${date-1}
            group by
                did
        ) b on a.did = b.did

with t_new_feed_2024 as (
    select
        did
    from 
        iceberg_zjyprc_hadoop.browser.dwm_browser_feed_did_history_df
    where
        date in (
            select 
                max(date)
            from 
                iceberg_zjyprc_hadoop.browser.dwm_browser_feed_did_history_df
            where
                date >= ${date-1}
        )
        and first_feed_day = ${date-1}
)

,t_dau_feed_dapan_2024 as (
    SELECT
        did
    FROM 
        iceberg_zjyprc_hadoop.browser.dwm_browser_event_aggregation_di 
    WHERE
        date = ${date-1}
        AND feed_status in ('true', 'false')
        AND coalesce(card_type,'') not in ('operation_top')
        AND expos_cnt + expose_enter_cnt + expose_noenter_cnt + click_cnt + click_enter_cnt + click_noenter_cnt + view_cnt + video_play_cnt > 0
    group by
        did
)

,t_dau_feed_toutiao_2024 as (
    SELECT
        did
    FROM 
        iceberg_zjyprc_hadoop.browser.dwm_browser_event_aggregation_di 
    WHERE
        date = ${date-1}
        and feed_status in ('true', 'false')
        and feed_alg_source IN ('toutiao')
        AND expos_cnt + expose_enter_cnt + expose_noenter_cnt + click_cnt + click_enter_cnt + click_noenter_cnt + view_cnt + video_play_cnt > 0
    group by 
        did
)

,t_valid_dapan_2024 as (
    SELECT
        did
    FROM 
        (
            select
                did
                ,sum(if(feed_status in ('true'),expos_cnt,0) + expose_enter_cnt) as expos_cnt
                ,sum(if(feed_status in ('true'),click_cnt,0) + click_enter_cnt) as click_cnt
            from 
                iceberg_zjyprc_hadoop.browser.dwm_browser_event_aggregation_di
            where
                date = ${date-1}
                and coalesce(card_type,'') not in ('operation_top')
                and coalesce(feed_channel,'') not in ('push')
            group by
                did
        ) t1
    WHERE
        expos_cnt >= 6 
        OR click_cnt >= 1
)

,t_valid_toutiao_2024 as (
    SELECT
        did
    FROM 
        (
            select
                did
                ,sum(if(feed_status in ('true'),expos_cnt,0) + expose_enter_cnt) as expos_cnt
                ,sum(if(feed_status in ('true'),click_cnt,0) + click_enter_cnt) as click_cnt
            from 
                iceberg_zjyprc_hadoop.browser.dwm_browser_event_aggregation_di
            where
                date = ${date-1}
                and coalesce(card_type,'') not in ('operation_top')
                and coalesce(feed_channel,'') not in ('push')
                AND feed_alg_source IN ('toutiao')
            group by
                did
        ) t1
    WHERE
        expos_cnt >= 6 
        OR click_cnt >= 1
)

,t_new_2024 as (
    select
        did 
    from
        iceberg_zjyprc_hadoop.browser.dwm_browser_did_history_df 
    where
        date in (
            select 
                max(date)
            from 
                iceberg_zjyprc_hadoop.browser.dwm_browser_did_history_df 
            where
                date >= ${date-1}
        )
        and first_app_day = ${date-1}
)

,t_app_dau_2024 as (
    select
        did 
    from 
        iceberg_zjyprc_hadoop.browser.dwm_browser_event_aggregation_di
    where
        date = ${date-1}
        and app_open_cnt > 0 
    group by
        did 
)

,t_first_open_type as (
    select
        did
        ,app_launch_way
        ,row_number() over (partition by did order by first_tm) as rid
    from
        iceberg_zjyprc_hadoop.browser.dwm_browser_event_aggregation_di
    where
        date = ${date-1}
        and coalesce(app_launch_way,'') != ''
        and first_tm >= unix_timestamp(cast(${date-1} as string), 'yyyyMMdd') * 1000
        and (
            expos_cnt > 0
            or expose_enter_cnt > 0
            or expose_noenter_cnt > 0
            or click_cnt > 0
            or click_enter_cnt > 0
            or click_noenter_cnt > 0
            or view_cnt > 0
            or video_play_cnt > 0
            or app_open_cnt > 0
        )
)

,t_is_first_open as (
    SELECT
        date
        ,distinct_id as did
        ,properties['sessionId'] as session_id
        ,row_number() over (partition by date,distinct_id order by e_ts) as rid
    FROM
        iceberg_zjyprc_hadoop.dw.dwd_ot_event_di_31000000442
    where
        date = ${date-1}
        and event_name in ('app_open','content_item_expose','content_item_expose_noenter','content_item_expose_enter')
        and properties['sessionId'] is not null
    having 
        rid = 1
)

,t_ad_exp_id as (
    select
        did
        ,concat_ws(',',array_distinct(split(concat_ws(',',collect_set(ad_exp_id)),','))) as ad_exp_id
    from 
        iceberg_zjyprc_hadoop.browser.dwm_browser_event_aggregation_di
    where
        date = ${date-1}
    group by
        did
)

,t_feed_alg_source_1 as (
    select
        *
        ,case 
            when feed_alg_source='toutiao' then '头条'
            when feed_alg_source='baidu' then '百度'
            when feed_alg_source='xiaomi' then '小米'
            when feed_alg_source='yidian' then '一点'
            else 'other'
        end as feed_alg_source_1
    from iceberg_zjyprc_hadoop.browser.dwm_browser_event_aggregation_di
    where date = ${date-1}
        and feed_status in ('true','false')
)

,t_feed_alg_source_max as (
    select
        t_feed_alg_source_1.did
        ,max(
            if(expos_cnt + expose_enter_cnt + expose_noenter_cnt + click_cnt + click_enter_cnt + click_noenter_cnt + view_cnt + video_play_cnt > 0
            ,feed_alg_source_1
            ,'')
        ) as feed_alg_source_max
    from 
        t_feed_alg_source_1
        join t_dau_feed_dapan_2024 on t_feed_alg_source_1.did = t_dau_feed_dapan_2024.did
    where
        coalesce(card_type,'') != 'operation_top'
    group by
        t_feed_alg_source_1.did
)

,t_content_vikingar as (
    SELECT
        regexp_extract(id, 'toutiao_newhome_(\\d+)', 1) as id
        ,max(
            case
                when cType in ('VIDEO') then 'inline_video'
                when cType in ('NEWS') then 'news'
                when cType in ('MINIVIDEO') then 'mini_video'
                when cType in ('SHORTSTORY') then 'shortstory'
                when cType in ('NOVEL') then 'novel'
                when cType in ('SHORTPLAY') then 'skit'
            end   
        ) as item_type_pool
        ,max(category[0]) as item_category
        ,max(subcategories[0]) as item_sub_category
        ,max(videodetail.duration) as item_video_length
    FROM
        hive_zjyprc_hadoop.feeds.content_databus_vikingar_batch_index
    WHERE
        date = ${date-2}
    group by 
        regexp_extract(id, 'toutiao_newhome_(\\d+)', 1)
)

,t_content_djy as (
    SELECT
        basic.id as id
        ,max(
            case
                when basic.cType in ('VIDEO') then 'inline_video'
                when basic.cType in ('NEWS') then 'news'
                when basic.cType in ('MINIVIDEO') then 'mini_video'
                when basic.cType in ('SHORTSTORY') then 'shortstory'
                when basic.cType in ('NOVEL') then 'novel'
                when basic.cType in ('SHORTPLAY') then 'skit'
            end   
        ) as item_type_pool
        ,max(basic.category[0]) as item_category
        ,max(basic.subCategory[0]) as item_sub_category
        ,max(basic.duration) as item_video_length
    FROM
        hive_zjyprc_hadoop.feeds.content_databus_dujiangyan_batch_index
    WHERE
        date = ${date-2}
    group by
        basic.id
)

, t_is_valid as (
    select date
        , did
        , is_include_push_valid
        , is_exclude_push_valid
    from iceberg_zjyprc_hadoop.browser.dim_browser_did_basic_label_di
    where date = ${date-1}

)


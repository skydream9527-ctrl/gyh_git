    ,if(t_dau_feed_dapan_2024.did IS NOT NULL, 1, 0) as is_dau_feed_dapan_2024
    ,if(t_dau_feed_toutiao_2024.did IS NOT NULL, 1, 0) as is_dau_feed_toutiao_2024
    ,if(t_valid_dapan_2024.did IS NOT NULL, 1, 0) as is_valid_dapan_2024
    ,if(t_valid_toutiao_2024.did IS NOT NULL, 1, 0) as is_valid_toutiao_2024
    ,if(t_new_2024.did IS NOT NULL, 1, 0) as is_new_2024
    ,if(t_new_feed_2024.did IS NOT NULL, 1, 0) as is_new_feed_2024 
    ,first_app_launch_way
    ,if(feed_channel = '推荐' and item_position = 5,1,0) as is_first_item
    ,if(t_is_first_open.did is not null, 1, 0) as is_first_open
    ,if(card_type = 'operation_top',1,0) as is_top
    ,item_alg_source
    ,first_tm
    ,last_tm
    ,page_origin
    ,book_type
    ,read_source
    ,next_novel
    ,last_read_source
    ,book_name
    ,skit_id
    ,chapter_count
    ,order
    ,is_feed_sliding
    , nvl(is_include_push_valid, 0) as is_include_push_valid
    , nvl(is_exclude_push_valid, 0) as is_exclude_push_valid

    ,app_open_cnt
    ,app_duration_cnt
    ,app_dura
    ,expos_cnt + expose_enter_cnt + expose_noenter_cnt as expos_cnt
    ,expose_enter_cnt + if(feed_status = 'true', expos_cnt, 0) as expose_enter_cnt
    ,expose_noenter_cnt + if(feed_status = 'false', expos_cnt, 0) as expose_noenter_cnt
    ,click_cnt + click_enter_cnt + click_noenter_cnt as click_cnt
    ,click_enter_cnt + if(feed_status = 'true', click_cnt, 0) as click_enter_cnt
    ,click_noenter_cnt + if(feed_status = 'false', click_cnt, 0) as click_noenter_cnt
    ,view_cnt
    ,view_quit_cnt
    ,view_event_dura
    ,video_play_cnt
    ,video_over_cnt
    ,video_over_event_dura
    ,video_play_fail_cnt
    ,max_play_dura
    ,play_all_over_cnt
    ,like_cnt
    ,unlike_cnt
    ,share_cnt
    ,collect_cnt
    ,enter_comment_cnt
    ,comment_cnt
    ,report_cnt
    ,feed_dura
    ,refresh_cnt
    ,request_cnt
    ,follow_cnt
    ,unfollow_cnt
    ,ad_content_expose_cnt
    ,ad_content_click_cnt
    ,ad_content_negative_cnt
    ,ad_content_request_client_cnt
    ,ad_content_request_sever_cnt
    ,ad_content_return_sever_cnt
    ,ad_content_return_client_cnt
    ,deeplink_ad_request_cnt
    ,deeplink_ad_return_cnt
    ,deeplink_ad_expose_cnt
    ,deeplink_ad_click_cnt
    ,deeplink_ad_success_cnt
    ,if(lower(coalesce(t_content_vikingar.item_type_pool,t_content_djy.item_type_pool,item_type))='news',click_cnt + click_enter_cnt + click_noenter_cnt,0) as news_vv_cnt
    ,if(lower(coalesce(t_content_vikingar.item_type_pool,t_content_djy.item_type_pool,item_type))='inline_video',video_play_cnt,0) as short_vv_cnt
    ,if(lower(coalesce(t_content_vikingar.item_type_pool,t_content_djy.item_type_pool,item_type)) in ('vertical_video','mini_video'),video_play_cnt,0) as mini_vv_cnt
    ,case 
        when lower(coalesce(t_content_vikingar.item_type_pool,t_content_djy.item_type_pool,item_type))='news' then click_cnt + click_enter_cnt + click_noenter_cnt--图文click、不包括PUSH内容的view（端外上报）
        when lower(coalesce(t_content_vikingar.item_type_pool,t_content_djy.item_type_pool,item_type))='inline_video' then video_play_cnt
        when lower(coalesce(t_content_vikingar.item_type_pool,t_content_djy.item_type_pool,item_type)) in ('vertical_video','mini_video') then video_play_cnt
        when lower(coalesce(t_content_vikingar.item_type_pool,t_content_djy.item_type_pool,item_type)) ='livestream' then video_play_cnt
        when lower(coalesce(t_content_vikingar.item_type_pool,t_content_djy.item_type_pool,item_type)) = 'skit' and t_dwm_agg.date >= 20251010 then video_play_cnt
        when lower(coalesce(t_content_vikingar.item_type_pool,t_content_djy.item_type_pool,item_type)) = 'shortstory' and t_dwm_agg.date >= 20251202 then book_read_cnt
        when lower(coalesce(t_content_vikingar.item_type_pool,t_content_djy.item_type_pool,item_type)) = 'novel' and t_dwm_agg.date >= 20251223 then book_read_cnt
        else 0
    end as consum_cnt
    ,case 
        when if(item_docid rlike 'djy',coalesce(lower(t_content_djy.item_type_pool),lower(item_type)),lower(item_type))='news' then view_cnt--图文view、包括PUSH内容的view（端内上报）
        when if(item_docid rlike 'djy',coalesce(lower(t_content_djy.item_type_pool),lower(item_type)),lower(item_type))='inline_video' then video_play_cnt 
        when if(item_docid rlike 'djy',coalesce(lower(t_content_djy.item_type_pool),lower(item_type)),lower(item_type)) in ('vertical_video','mini_video') then video_play_cnt
        when if(item_docid rlike 'djy',coalesce(lower(t_content_djy.item_type_pool),lower(item_type)),lower(item_type)) ='livestream' then video_play_cnt
        when if(item_docid rlike 'djy',coalesce(lower(t_content_djy.item_type_pool),lower(item_type)),lower(item_type)) = 'skit' and t_dwm_agg.date >= 20251010 then video_play_cnt
        when if(item_docid rlike 'djy',coalesce(lower(t_content_djy.item_type_pool),lower(item_type)),lower(item_type)) = 'shortstory' and t_dwm_agg.date >= 20251202 then book_read_cnt
        when if(item_docid rlike 'djy',coalesce(lower(t_content_djy.item_type_pool),lower(item_type)),lower(item_type)) = 'novel' and t_dwm_agg.date >= 20251223 then book_read_cnt
        else 0
    end as consum_cnt_v2
    ,case 
        when if(item_docid rlike 'djy',coalesce(lower(t_content_djy.item_type_pool),lower(item_type)),lower(item_type))='news' then view_event_dura
        when if(item_docid rlike 'djy',coalesce(lower(t_content_djy.item_type_pool),lower(item_type)),lower(item_type))='inline_video' then video_over_event_dura
        when if(item_docid rlike 'djy',coalesce(lower(t_content_djy.item_type_pool),lower(item_type)),lower(item_type)) in ('vertical_video','mini_video') then video_over_event_dura
        when if(item_docid rlike 'djy',coalesce(lower(t_content_djy.item_type_pool),lower(item_type)),lower(item_type))='livestream' then video_over_event_dura
        when if(item_docid rlike 'djy',coalesce(lower(t_content_djy.item_type_pool),lower(item_type)),lower(item_type)) = 'skit' and t_dwm_agg.date >= 20251010 then video_over_event_dura
        when if(item_docid rlike 'djy',coalesce(lower(t_content_djy.item_type_pool),lower(item_type)),lower(item_type)) = 'shortstory' and t_dwm_agg.date >= 20251202 then book_read_dura
        when if(item_docid rlike 'djy',coalesce(lower(t_content_djy.item_type_pool),lower(item_type)),lower(item_type)) = 'novel' and t_dwm_agg.date >= 20251223 then book_read_dura
        else 0
    end as consum_dura
    ,search_security_cnt
    ,search_cnt
    ,sug_expose_cnt
    ,third_packagename
    ,feed_trace_id
    ,max_video_play_percent
    ,if(lower(item_type) in('news','inline_video','vertical_video','mini_video'),coalesce(t_content_vikingar.item_video_length,t_content_djy.item_video_length),t_dwm_agg.item_video_length) as item_video_length--三体裁用内容理解的长度、多体裁用打点的长度。
    ,vaild_play_cnt
    ,vaild_view_cnt
    ,max_view_percent
    ,item_cpauthorid
    ,user_switch
    ,coalesce(t_content_vikingar.item_type_pool,t_content_djy.item_type_pool) as item_type_pool
    ,item_order
    ,regexp_replace(djy_rec_expid, '\\.0+', '')
    ,root_gid
    ,is_click_content_enter,
    comment_area_dura,
    view_all_quit_cnt,
    if(lower(item_type)='news',vaild_view_quit_cnt, vaild_play_over_cnt) as vaild_play_view_over_cnt,
    negtive_cnt,
    report_cnt_new,
    rubbish_cnt,
    repeat_cnt,
    shield_cnt,
    dislike_cnt,
    if(item_video_switch_way = '手动上滑切换',fast_slide_play_cnt,0) as video_fast_slide_cnt
    ,shortstory_read_cnt
    ,shortstory_read_dura
    ,turn_pages
    , if(lower(item_type) in ('novel', 'shortstory'), book_read_cnt , 0) as book_read_cnt 
    , if(lower(item_type) in ('novel', 'shortstory'), book_read_vv  , 0) as book_read_vv  
    , if(lower(item_type) in ('novel', 'shortstory'), book_read_dura, 0) as book_read_dura
    , item_substyle
    , fullscreen_click_cnt
FROM
    iceberg_zjyprc_hadoop.browser.dwm_browser_event_aggregation_di as t_dwm_agg
    left join t_new_feed_2024 on t_dwm_agg.did = t_new_feed_2024.did
    left join t_dau_feed_dapan_2024 on t_dwm_agg.did = t_dau_feed_dapan_2024.did
    left join t_dau_feed_toutiao_2024 on t_dwm_agg.did = t_dau_feed_toutiao_2024.did
    left join t_valid_dapan_2024 on t_dwm_agg.did = t_valid_dapan_2024.did
    left join t_valid_toutiao_2024 on t_dwm_agg.did = t_valid_toutiao_2024.did
    left join t_new_2024 on t_dwm_agg.did = t_new_2024.did
    left join t_app_dau_2024 on t_dwm_agg.did = t_app_dau_2024.did
    left join (
        --first_open_type 当天首次打开方式
        select
            did
            ,app_launch_way as first_app_launch_way
        from
            t_first_open_type
        where
            rid = 1
    ) t1 on t_dwm_agg.did = t1.did
    left join t_ad_exp_id on t_dwm_agg.did = t_ad_exp_id.did 
    left join t_is_first_open on t_dwm_agg.did = t_is_first_open.did and t_dwm_agg.session_id = t_is_first_open.session_id
    left join t_feed_alg_source_max on t_dwm_agg.did = t_feed_alg_source_max.did
    left join t_content_vikingar on t_dwm_agg.item_docid = t_content_vikingar.id
    left join t_content_djy on t_dwm_agg.item_docid = t_content_djy.id
    left join t_is_valid on t_dwm_agg.did = t_is_valid.did
WHERE
    t_dwm_agg.date = ${date-1}
    and coalesce(t_dwm_agg.item_docid,'') != ''
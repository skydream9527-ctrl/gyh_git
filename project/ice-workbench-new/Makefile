.PHONY: help install install-sandbox backend frontend dev seed test fmt clean pack pack-clean reset-data \
        prod-build prod-run prod \
        docker-build docker-up docker-down docker-upgrade docker-logs

VERSION ?= $(shell date +%Y%m%d)
PKG_NAME = ice-workbench-$(VERSION).zip
# 生产监听端口（ICE_BIND_PORT 环境变量可覆盖；默认 8000）
PROD_PORT ?= $(if $(ICE_BIND_PORT),$(ICE_BIND_PORT),8000)
# 绑定地址：0.0.0.0 让公网 / 局域网可达
PROD_HOST ?= 0.0.0.0
# uvicorn worker 数。多 worker 提升 CPU 密集场景吞吐（流式 JSON、markdown）；
# scheduler/WS inflight 已加文件锁，多 worker 安全。可 ICE_WORKERS=N 覆盖。
PROD_WORKERS ?= $(if $(ICE_WORKERS),$(ICE_WORKERS),4)
# WebSocket ping/pong：默认 20/20s 太紧——长会话/多会话并发时 event loop
# 偶尔被同步 IO 卡 >20s，服务端就会把 ws 关掉触发 STREAM_INTERRUPTED。
# 给 30/60 留够缓冲。同时后端在 _handle_user_message 里有应用层 keepalive。
UVICORN_WS_FLAGS = --ws-ping-interval 30 --ws-ping-timeout 60

help:
	@echo "ICE Data Workbench v3 — local dev + deploy"
	@echo ""
	@echo "  make install         install backend (pip) + frontend (npm)"
	@echo "  make install-sandbox bootstrap Python sandbox venv (data-analysis agent)"
	@echo "  make dev         run backend + frontend in parallel (LOCALHOST ONLY :5173 + :8000)"
	@echo "  make backend     only backend on :8000"
	@echo "  make frontend    only frontend on :5173 (LOCALHOST ONLY by default)"
	@echo ""
	@echo "  make prod        build frontend + run single-port server (LAN/WAN safe)"
	@echo "  make prod-build  only build frontend dist"
	@echo "  make prod-run    only start backend on \$$PROD_HOST:\$$PROD_PORT (0.0.0.0:8000)"
	@echo ""
	@echo "  ⚠ Never run vite dev (\`make dev\` / \`make frontend\`) on a LAN-reachable IP."
	@echo "    For phone testing on the same WiFi, use \`make prod\` — it serves the static"
	@echo "    build via uvicorn with the security-headers middleware. The dev server leaks"
	@echo "    full /src source + sourcemaps and lacks security headers."
	@echo ""
	@echo ""
	@echo "  Docker 自托管（详见 docs/SELF_HOSTING.md）："
	@echo "  make docker-build    docker compose build"
	@echo "  make docker-up       后台起容器，提示初始 admin 密码位置"
	@echo "  make docker-down     停止并删除容器（数据保留）"
	@echo "  make docker-upgrade  git pull + 重建镜像 + 滚动更新"
	@echo "  make docker-logs     跟踪容器日志"
	@echo ""
	@echo "  make seed        one-shot seed bootstrap"
	@echo "  make test        backend pytest"
	@echo "  make pack        build a portable zip (excludes .env + venv/node_modules; ships .env.example)"
	@echo "  make pack-clean  pack + delete runtime data first (for clean handoff)"
	@echo "  make reset-data  wipe runtime data (.cache, users/<uid>, tasks/<tid>)"
	@echo "  make clean       remove venv + node_modules + caches"

install:
	cd backend && python3 -m venv .venv && . .venv/bin/activate && pip install -U pip && pip install -e ".[dev]"
	cd frontend && npm install

install-sandbox:
	bash backend/scripts/bootstrap_sandbox_venv.sh

backend:
	cd backend && . .venv/bin/activate && uvicorn app.main:app --reload --port 8000 $(UVICORN_WS_FLAGS)

frontend:
	cd frontend && npm run dev

dev:
	@echo "Starting backend (8000) + frontend (5173) — Ctrl-C to stop both"
	@(cd backend && . .venv/bin/activate && uvicorn app.main:app --reload --port 8000 $(UVICORN_WS_FLAGS)) & \
	 (cd frontend && npm run dev) ; \
	 wait

prod-build:
	@echo "Building frontend dist…"
	cd frontend && npm run build
	@echo "  ✓ frontend/dist/ ready"

prod-run:
	@echo "Starting backend on $(PROD_HOST):$(PROD_PORT) (single-port, serves SPA + API + WS) — $(PROD_WORKERS) workers"
	cd backend && . .venv/bin/activate && \
	  uvicorn app.main:app --host $(PROD_HOST) --port $(PROD_PORT) --workers $(PROD_WORKERS) $(UVICORN_WS_FLAGS)

prod: prod-build prod-run

seed:
	cd backend && . .venv/bin/activate && python -m app.seed.runner

generate-api:
	@echo "Exporting OpenAPI schema from backend…"
	cd backend && . .venv/bin/activate && python scripts/export_openapi.py
	@echo "Generating frontend TypeScript types…"
	cd frontend && npm run generate:api
	@echo "  ✓ frontend/src/types/api.generated.ts updated"

test:
	cd backend && . .venv/bin/activate && pytest -q

fmt:
	cd backend && . .venv/bin/activate && ruff check --fix app tests || true
	cd frontend && npm run lint -- --fix || true

# Wipe runtime-generated data (safe to re-run; seed re-creates admin on next boot).
reset-data:
	@echo "Removing runtime data (.cache + per-user + per-task)…"
	@rm -rf .cache
	@find users -mindepth 1 -maxdepth 1 -type d ! -name 'README*' -exec rm -rf {} +
	@find tasks -mindepth 1 -maxdepth 1 -type d ! -name 'README*' -exec rm -rf {} +
	@find agents -name 'cards.md' -path '*/prompt/cards.md' -delete 2>/dev/null || true
	@find . -name '*.lock' -path '*/tasks/*' -delete 2>/dev/null || true
	@echo "  done."

clean:
	rm -rf backend/.venv backend/.venv-sandbox backend/.pytest_cache
	find backend -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null || true
	rm -rf frontend/node_modules frontend/dist
	rm -rf .cache

# Build a self-contained zip for handoff. Excludes anything regenerated by
# `make install` or runtime. SECURITY: .env is NOT bundled (it carries LLM /
# Feishu / Aegis credentials). The zip ships .env.example instead; deploy.sh
# copies it to .env on first run and auto-generates a strong ICE_SECRET_KEY,
# so the target still boots without manual secret setup. Operators fill in
# the LLM / Feishu keys after unzip.
pack: prod-build
	@command -v zip >/dev/null 2>&1 || { echo "zip not found"; exit 1; }
	@echo "Packing $(PKG_NAME)…"
	@rm -f $(PKG_NAME)
	@zip -r $(PKG_NAME) . \
	  -x '*.git/*' '*.git' \
	  -x '.env' '*/.env' \
	  -x '*backend/.venv/*' \
	  -x '*backend/.venv-sandbox/*' \
	  -x '*frontend/node_modules/*' \
	  -x '.cache/*' '*/.cache/*' \
	  -x 'users/[a-f0-9]*/*' \
	  -x 'tasks/[a-f0-9]*/*' \
	  -x '*__pycache__/*' \
	  -x '*.pyc' '*.pyo' \
	  -x '*.pytest_cache/*' \
	  -x '*.ruff_cache/*' \
	  -x '*.mypy_cache/*' \
	  -x 'extracted/*' \
	  -x 'ice_data_workspace_v2.zip' \
	  -x '.DS_Store' '*/.DS_Store' \
	  -x '*.log' \
	  -x '*.lock' \
	  -x 'ice-workbench-*.zip' \
	  -x '.tmp-*' \
	  >/dev/null
	@echo ""
	@echo "  ✓ $(PKG_NAME)  ($$(du -h $(PKG_NAME) | cut -f1))"
	@echo ""
	@echo "  Send this single file to the target machine, then on it:"
	@echo "    unzip $(PKG_NAME) -d ice-workbench"
	@echo "    cd ice-workbench"
	@echo "    ./deploy.sh --run    # 自动从 .env.example 建 .env + 生成 ICE_SECRET_KEY"
	@echo ""
	@echo "  ⚠ .env 未打包（含密钥）。解压后按需在 .env 填 LLM / 飞书 凭证再起服务。"
	@echo ""

pack-clean: reset-data pack

# ---------- Docker 自托管 target（详见 docs/SELF_HOSTING.md） ----------
docker-build:
	docker compose build

docker-up:
	@if [ ! -f .env ]; then \
		echo "  ✗ .env 不存在。先 cp .env.example .env 并改 ICE_SECRET_KEY 等密钥。"; exit 1; \
	fi
	docker compose up -d
	@echo ""
	@echo "  ✓ 已启动。访问： http://localhost:$${ICE_BIND_PORT:-8000}"
	@echo "  ✓ 取初始 admin 密码（首次启动后约 30s）："
	@echo "      docker exec ice-workbench cat /app/.cache/initial_admin_password.txt"
	@echo ""

docker-down:
	docker compose down

docker-upgrade:
	@echo "升级前请先备份："
	@echo "  tar czf backup-\$$(date +%F).tgz .env users tasks files agents skills .cache"
	@echo ""
	git pull
	docker compose up -d --build

docker-logs:
	docker compose logs -f

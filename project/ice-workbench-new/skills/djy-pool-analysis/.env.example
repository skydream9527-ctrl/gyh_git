# djy-pool-analysis skill · 飞书推送凭据
# 实际使用前：复制为 .env 并填入真实值（chmod 600 保权限）
# feishu_post.py 优先用 webhook；如果不配置 webhook，则会读取项目根 .env 中的
# FEISHU_APP_ID / FEISHU_APP_SECRET，并用下面的 FEISHU_RECEIVE_ID 走 IM API 推送。

FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/REPLACE_ME
FEISHU_SECRET=REPLACE_ME

# 可选：使用飞书开放平台机器人直接发消息时配置。
# FEISHU_RECEIVE_ID_TYPE 支持 chat_id / open_id / union_id / email / user_id。
FEISHU_RECEIVE_ID=
FEISHU_RECEIVE_ID_TYPE=chat_id

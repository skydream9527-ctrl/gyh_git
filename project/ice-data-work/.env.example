# ICE-DATA-WORK 环境变量样例（复制为 .env 后填写）

# ---- 核心 ----
IDW_SECRET_KEY=change-me-至少32字节随机串            # JWT 签名密钥
DATA_ROOT=                                          # 留空=自动解析到仓库根（G3 数据目录所在）
IDW_BIND_HOST=0.0.0.0
IDW_BIND_PORT=8000

# ---- 数据库 / 向量 ----
# SQLite 索引在 .cache/index.db（自动）；pgvector 用于记忆语义检索，缺省时降级关键词
DATABASE_URL=postgresql+psycopg://idw:idw@localhost:5432/idw   # docker-compose 默认
IDW_PGVECTOR_ENABLED=false                          # true 时启用语义检索

# ---- LLM 网关（mify，按 model 前缀路由 4 协议）----
MIFY_GATEWAY_BASE_URL=
MIFY_GATEWAY_API_KEY=
ANTHROPIC_API_KEY=                                  # 旧版回退，仅 mify 未配置时启用

# ---- 飞书 OAuth（不填时按钮返回 FEISHU_NOT_CONFIGURED）----
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_HOST=https://open.feishu.cn                  # 小米内部改内部域名
FEISHU_REDIRECT_URI=http://localhost:5173/auth/feishu/callback

# ---- Kyuubi SQL 网关（不填时 SQL skill 返回 KYUUBI_NOT_CONFIGURED）----
KYUUBI_HOST=
KYUUBI_PORT=
KYUUBI_USER=

# ---- 米盾 Aegis（X-Proxy-UserDetail RSA 校验，多 key 逗号分隔）----
AEGIS_PUBLIC_KEYS=

# ---- 特性开关（保守默认，灰度开启）----
IDW_TWIN_ENABLED=true                               # 一等 Twin（v1 开）
IDW_SELF_EVOLVE_ENABLED=false                       # Skill/Agent 自演进（M6）
IDW_DAEMON_ENABLED=false                            # 本机 Runtime（二期 P2-01）
IDW_CROSS_TWIN_ENABLED=false                        # 跨用户 Twin 协作（二期 P2-02）
IDW_VOICE_ENABLED=false                             # 语音输入输出
